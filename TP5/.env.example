AIRFLOW_UID=50000

# Métadonnées Airflow (technique)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

AIRFLOW_ADMIN_USERNAME=airflow
AIRFLOW_ADMIN_PASSWORD=airflow

# Base de données métier / cible du chargement (technique)
WEATHER_DB_USER=weather
WEATHER_DB_PASSWORD=weather
WEATHER_DB_NAME=weather

# Connexion Airflow vers la BDD métier (consommée par PostgresHook via conn_id "weather_db")
AIRFLOW_CONN_WEATHER_DB=postgresql://weather:weather@weather-db:5432/weather

# Noms de tables (technique)
WEATHER_TABLE=weather_measurements
INGESTION_TABLE=ingestion_log
QUALITY_TABLE=quality_issues

# API (technique)
OPEN_METEO_URL=https://api.open-meteo.com/v1/forecast